= { by axiom 1 (commutativity_of_add) }
  inv(add(a, inv(add(add(a, inv(b)), inv(add(inv(add(a, inv(b))), add(add(inv(add(X, inv(b))), inv(add(inv(X), inv(b)))), a)))))))
= { by lemma 5 }

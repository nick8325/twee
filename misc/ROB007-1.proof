= { by axiom 1 (commutativity_of_add) R->L }
  inv(add(inv(add(inv(b), inv(add(a, inv(b))))), inv(add(add(a, inv(b)), inv(add(add(inv(add(X, inv(b))), inv(add(inv(X), inv(b)))), add(inv(add(a, inv(b))), a)))))))
= { by axiom 1 (commutativity_of_add) R->L }
  inv(add(inv(add(add(a, inv(b)), inv(add(add(inv(add(X, inv(b))), inv(add(inv(X), inv(b)))), add(inv(add(a, inv(b))), a))))), inv(add(inv(b), inv(add(a, inv(b)))))))
= { by axiom 4 (robbins_axiom) R->L }
  inv(add(inv(add(add(a, inv(b)), inv(add(add(inv(add(X, inv(b))), inv(add(inv(X), inv(b)))), add(inv(add(a, inv(b))), a))))), inv(add(inv(b), inv(add(inv(add(inv(add(a, inv(b))), add(add(inv(add(X, inv(b))), inv(add(inv(X), inv(b)))), a))), inv(add(inv(add(a, inv(b))), inv(add(add(inv(add(X, inv(b))), inv(add(inv(X), inv(b)))), a))))))))))
= { by axiom 1 (commutativity_of_add) R->L }
  inv(add(inv(add(add(a, inv(b)), inv(add(add(inv(add(X, inv(b))), inv(add(inv(X), inv(b)))), add(inv(add(a, inv(b))), a))))), inv(add(inv(b), inv(add(inv(add(inv(add(a, inv(b))), add(add(inv(add(X, inv(b))), inv(add(inv(X), inv(b)))), a))), inv(add(inv(add(a, inv(b))), inv(add(a, add(inv(add(X, inv(b))), inv(add(inv(X), inv(b))))))))))))))
= { by axiom 1 (commutativity_of_add) R->L }
  inv(add(inv(add(add(a, inv(b)), inv(add(add(inv(add(X, inv(b))), inv(add(inv(X), inv(b)))), add(inv(add(a, inv(b))), a))))), inv(add(inv(b), inv(add(inv(add(inv(add(a, inv(b))), add(add(inv(add(X, inv(b))), inv(add(inv(X), inv(b)))), a))), inv(add(inv(add(a, add(inv(add(X, inv(b))), inv(add(inv(X), inv(b)))))), inv(add(a, inv(b)))))))))))
= { by axiom 1 (commutativity_of_add) }
  inv(add(inv(add(add(a, inv(b)), inv(add(add(inv(add(X, inv(b))), inv(add(inv(X), inv(b)))), add(inv(add(a, inv(b))), a))))), inv(add(inv(b), inv(add(inv(add(inv(add(a, inv(b))), add(add(inv(add(X, inv(b))), inv(add(inv(X), inv(b)))), a))), inv(add(inv(add(a, add(inv(add(X, inv(b))), inv(add(inv(X), inv(b)))))), inv(add(inv(b), a))))))))))

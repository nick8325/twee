= { by lemma 15 R->L }
  inv(add(inv(add(Y, inv(add(inv(Y), add(X, inv(add(inv(Y), inv(X)))))))), inv(add(inv(Y), inv(add(inv(Y), add(X, inv(add(inv(Y), inv(X))))))))))
= { by lemma 16 }
  inv(add(inv(Y), add(X, inv(add(inv(Y), inv(X))))))
= { by lemma 5 }
  inv(add(X, add(inv(Y), inv(add(inv(Y), inv(X))))))
= { by axiom 1 (commutativity_of_add) }
  inv(add(X, add(inv(Y), inv(add(inv(X), inv(Y))))))

Lemma 18: inv(add(inv(add(X, inv(b))), inv(add(X, add(a, b))))) = X.
Proof:

The conjecture is true! Here is a proof.

Axiom 1 (commutativity_of_add): add(X, Y) = add(Y, X).
Axiom 2 (condition): inv(add(a, b)) = inv(b).
Axiom 3 (associativity_of_add): add(add(X, Y), Z) = add(X, add(Y, Z)).
Axiom 4 (robbins_axiom): inv(add(inv(add(X, Y)), inv(add(X, inv(Y))))) = X.

Lemma 5: add(X, add(Y, Z)) = add(Y, add(X, Z)).
Proof:
  add(X, add(Y, Z))
= { by axiom 1 (commutativity_of_add) R->L }
  add(add(Y, Z), X)
= { by axiom 3 (associativity_of_add) }
  add(Y, add(Z, X))
= { by axiom 1 (commutativity_of_add) }
  add(Y, add(X, Z))

Lemma 6: add(Y, add(Z, X)) = add(X, add(Y, Z)).
Proof:
  add(Y, add(Z, X))
= { by axiom 1 (commutativity_of_add) R->L }
  add(add(Z, X), Y)
= { by axiom 1 (commutativity_of_add) }
  add(add(X, Z), Y)
= { by axiom 3 (associativity_of_add) }
  add(X, add(Z, Y))
= { by axiom 1 (commutativity_of_add) }
  add(X, add(Y, Z))

Lemma 7: add(Z, add(Y, X)) = add(X, add(Y, Z)).
Proof:
  add(Z, add(Y, X))
= { by lemma 6 }
  add(X, add(Z, Y))
= { by axiom 1 (commutativity_of_add) }
  add(X, add(Y, Z))

Lemma 8: inv(add(inv(add(X, inv(Y))), inv(add(X, Y)))) = X.
Proof:
  inv(add(inv(add(X, inv(Y))), inv(add(X, Y))))
= { by axiom 1 (commutativity_of_add) R->L }
  inv(add(inv(add(X, Y)), inv(add(X, inv(Y)))))
= { by axiom 4 (robbins_axiom) }
  X

Lemma 9: inv(add(inv(b), inv(add(inv(a), b)))) = b.
Proof:
  inv(add(inv(b), inv(add(inv(a), b))))
= { by axiom 1 (commutativity_of_add) R->L }
  inv(add(inv(b), inv(add(b, inv(a)))))
= { by axiom 1 (commutativity_of_add) R->L }
  inv(add(inv(add(b, inv(a))), inv(b)))
= { by axiom 2 (condition) R->L }
  inv(add(inv(add(b, inv(a))), inv(add(a, b))))
= { by axiom 1 (commutativity_of_add) R->L }
  inv(add(inv(add(b, inv(a))), inv(add(b, a))))
= { by lemma 8 }
  b

Lemma 10: inv(add(inv(add(a, inv(b))), inv(b))) = a.
Proof:
  inv(add(inv(add(a, inv(b))), inv(b)))
= { by axiom 1 (commutativity_of_add) R->L }
  inv(add(inv(b), inv(add(a, inv(b)))))
= { by axiom 2 (condition) R->L }
  inv(add(inv(add(a, b)), inv(add(a, inv(b)))))
= { by axiom 4 (robbins_axiom) }
  a

Lemma 11: inv(add(inv(add(X, add(Y, Z))), inv(add(Z, inv(add(X, Y)))))) = Z.
Proof:
  inv(add(inv(add(X, add(Y, Z))), inv(add(Z, inv(add(X, Y))))))
= { by lemma 6 }
  inv(add(inv(add(Z, add(X, Y))), inv(add(Z, inv(add(X, Y))))))
= { by axiom 4 (robbins_axiom) }
  Z

Lemma 12: inv(add(inv(add(X, Y)), inv(add(inv(Y), X)))) = X.
Proof:
  inv(add(inv(add(X, Y)), inv(add(inv(Y), X))))
= { by axiom 1 (commutativity_of_add) R->L }
  inv(add(inv(add(X, Y)), inv(add(X, inv(Y)))))
= { by axiom 4 (robbins_axiom) }
  X

Lemma 13: inv(add(inv(add(X, Y)), inv(add(Y, inv(X))))) = Y.
Proof:
  inv(add(inv(add(X, Y)), inv(add(Y, inv(X)))))
= { by axiom 1 (commutativity_of_add) R->L }
  inv(add(inv(add(Y, X)), inv(add(Y, inv(X)))))
= { by axiom 4 (robbins_axiom) }
  Y

Lemma 14: inv(add(inv(b), inv(add(add(a, inv(b)), add(a, inv(b)))))) = a.
Proof:
  inv(add(inv(b), inv(add(add(a, inv(b)), add(a, inv(b))))))
= { by axiom 1 (commutativity_of_add) R->L }
  inv(add(inv(add(add(a, inv(b)), add(a, inv(b)))), inv(b)))
= { by axiom 1 (commutativity_of_add) }
  inv(add(inv(add(add(a, inv(b)), add(inv(b), a))), inv(b)))
= { by axiom 3 (associativity_of_add) R->L }
  inv(add(inv(add(add(add(a, inv(b)), inv(b)), a)), inv(b)))
= { by lemma 12 R->L }
  inv(add(inv(add(add(add(a, inv(b)), inv(b)), a)), inv(add(inv(add(inv(b), add(a, inv(b)))), inv(add(inv(add(a, inv(b))), inv(b)))))))
= { by lemma 10 }
  inv(add(inv(add(add(add(a, inv(b)), inv(b)), a)), inv(add(inv(add(inv(b), add(a, inv(b)))), a))))
= { by axiom 1 (commutativity_of_add) }
  inv(add(inv(add(add(add(a, inv(b)), inv(b)), a)), inv(add(a, inv(add(inv(b), add(a, inv(b))))))))
= { by axiom 1 (commutativity_of_add) }
  inv(add(inv(add(add(add(a, inv(b)), inv(b)), a)), inv(add(a, inv(add(add(a, inv(b)), inv(b)))))))
= { by lemma 13 }
  a

Lemma 15: inv(add(X, inv(add(X, add(Y, inv(add(X, inv(Y)))))))) = inv(add(X, inv(Y))).
Proof:
  inv(add(X, inv(add(X, add(Y, inv(add(X, inv(Y))))))))
= { by axiom 1 (commutativity_of_add) R->L }
  inv(add(X, inv(add(X, add(inv(add(X, inv(Y))), Y)))))
= { by lemma 5 R->L }
  inv(add(X, inv(add(inv(add(X, inv(Y))), add(X, Y)))))
= { by axiom 1 (commutativity_of_add) R->L }
  inv(add(inv(add(inv(add(X, inv(Y))), add(X, Y))), X))
= { by lemma 8 R->L }
  inv(add(inv(add(inv(add(X, inv(Y))), add(X, Y))), inv(add(inv(add(X, inv(Y))), inv(add(X, Y))))))
= { by axiom 4 (robbins_axiom) }
  inv(add(X, inv(Y)))

Lemma 16: inv(add(inv(add(X, Y)), inv(add(inv(X), Y)))) = Y.
Proof:

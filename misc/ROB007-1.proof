= { by axiom 3 (associativity_of_add) }
  inv(add(inv(add(X, add(add(a, inv(b)), inv(add(add(a, inv(b)), inv(add(a, inv(b)))))))), inv(add(X, add(inv(add(add(a, inv(b)), inv(add(a, inv(b))))), inv(add(a, inv(b))))))))
= { by axiom 1 (commutativity_of_add) }
